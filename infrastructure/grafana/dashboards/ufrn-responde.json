{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "timeseries", "title": "Request rate", "id": 1,
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (application) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{application}}"}]
    },
    {
      "type": "timeseries", "title": "Error rate", "id": 2,
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "sum by (application, status) (rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m]))", "legendFormat": "{{application}} {{status}}"}]
    },
    {
      "type": "timeseries", "title": "HTTP P50 / P95 / P99", "id": 3,
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "P50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "P95"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "P99"}
      ]
    },
    {
      "type": "stat", "title": "Available instances", "id": 4,
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "targets": [{"expr": "sum by (job) (up)", "legendFormat": "{{job}}"}]
    },
    {
      "type": "timeseries", "title": "Circuit breaker states", "id": 5,
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "targets": [{"expr": "resilience4j_circuitbreaker_state", "legendFormat": "{{name}} {{state}}"}]
    },
    {
      "type": "timeseries", "title": "Bulkhead capacity", "id": 6,
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 8},
      "targets": [{"expr": "resilience4j_bulkhead_available_concurrent_calls", "legendFormat": "{{name}}"}]
    },
    {
      "type": "timeseries", "title": "Groq token usage", "id": 7,
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 8},
      "targets": [{"expr": "sum by (type) (rate(rag_groq_tokens_total[5m]))", "legendFormat": "{{type}}"}]
    },
    {
      "type": "timeseries", "title": "Grounding and tool calls", "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [
        {"expr": "sum by (grounded) (rate(rag_answers_total[5m]))", "legendFormat": "grounded={{grounded}}"},
        {"expr": "sum by (tool) (rate(rag_tools_calls_total[5m]))", "legendFormat": "{{tool}}"}
      ]
    },
    {
      "type": "timeseries", "title": "JVM memory", "id": 9,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [{"expr": "sum by (application, area) (jvm_memory_used_bytes)", "legendFormat": "{{application}} {{area}}"}]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 41,
  "tags": ["ufrn-responde"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "title": "UFRN Responde",
  "uid": "ufrn-responde",
  "version": 1
}
