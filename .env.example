# Copy this file to .env before using Docker Compose.
RELEASE_VERSION=0.0.1
BUILD_REVISION=replace-with-git-commit

CONFIG_SERVER_URL=http://config-server:8888
# Override this with a remote Git URL in deployed environments.
CONFIG_GIT_URI=http://config-git/config.git
CONFIG_GIT_DEFAULT_LABEL=main
CONFIG_GIT_USERNAME=
CONFIG_GIT_PASSWORD=

EUREKA_PEERS=http://eureka-1:8761/eureka/,http://eureka-2:8761/eureka/,http://eureka-3:8761/eureka/
EUREKA_URL=http://eureka-cluster:8761/eureka/

ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
TRACING_SAMPLING_PROBABILITY=1.0
GATEWAY_CIRCUIT_BREAKER_RECOVERY_ENABLED=true
QUESTION_SERVICE_CIRCUIT_BREAKER_RECOVERY_ENABLED=true

# Attached resource handles. Override these without rebuilding application images.
NORMALIZER_URL=http://question-normalizer/normalizeQuestion
RAG_GRAPHQL_URL=http://rag-service/graphql
REGULATION_MCP_URL=http://regulation-mcp:8084
GROQ_BASE_URL=https://api.groq.com/openai/v1/
OLLAMA_BASE_URL=http://ollama:11434
TAVILY_MCP_URL=https://mcp.tavily.com

# Required secrets. Replace every placeholder before starting Compose.
GROQ_API_KEY=replace-with-groq-api-key
TAVILY_API_KEY=replace-with-tavily-api-key
POSTGRES_DB=ufrn_responde
POSTGRES_USER=ufrn_responde
POSTGRES_PASSWORD=replace-with-strong-database-password
POSTGRES_URL=jdbc:postgresql://postgres:5432/ufrn_responde
GROQ_CHAT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_CONCURRENT_CALLS=3
GROQ_LIMIT_FOR_PERIOD=3
OLLAMA_EMBEDDING_MODEL=bge-m3:567m
RAG_SIMILARITY_THRESHOLD=0.45
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password

CONFIG_SERVER_HOST_PORT=8888
EUREKA_1_HOST_PORT=8761
EUREKA_2_HOST_PORT=8762
EUREKA_3_HOST_PORT=8763
GATEWAY_HOST_PORT=8080
PROMETHEUS_HOST_PORT=9090
ZIPKIN_HOST_PORT=9411
GRAFANA_HOST_PORT=3000
